generator client {
  provider = "prisma-client-js"
}

// TODO: migrar a postrges y aprovechar mejor las relaciones
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique(map: "Usuario_email_key")
  nombre               String?
  apellido             String?
  password             String?
  rol                  UserRole   @default(ABOGADO)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  emailVerified        DateTime?
  image                String?
  name                 String?
  isActive             Boolean    @default(true)
  creadoPor            String?
  debeResetearPassword Boolean    @default(false)
  ultimoAcceso         DateTime?
  colaboracionesAsignadas CasoColaborador[] @relation("AsignadorColaboracion")


  accounts             Account[]
  bitacoras            Bitacora[]
  casos                Caso[]     @relation("AbogadoCasos")
  clientes             Cliente[]  @relation("AbogadoClientes")
  clienteVinculado     Cliente?   @relation("ClienteUsuarioPortal")
  pagosValidados       Pago[]
  sessions             Session[]
  tareas               Tarea[]
  colaboraciones CasoColaborador[]

  @@map("usuario")
}

model Cliente {
  id              String        @id @default(uuid())
  nombre          String
  apellido        String?
  email           String?       @unique(map: "Cliente_email_key")
  numeroDocumento String        @unique
  tipoDocumento   TipoDocumento @default(DNI)
  direccion       String?
  telefono        String?       @unique(map: "Cliente_telefono_key")
  estado          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  abogadoId       String
  activo          Boolean       @default(true)
  condicionIva    CondicionIVA  @default(CONSUMIDOR_FINAL)
  notasInternas   String?       @db.Text
  tipoPersona     TipoPersona   @default(FISICA)
  creadoPorId     String?
  usuarioPortalId String?       @unique
  casos           Caso[]        @relation("ClienteCasos")
  abogado         User          @relation("AbogadoClientes", fields: [abogadoId], references: [id])
  usuarioPortal   User?         @relation("ClienteUsuarioPortal", fields: [usuarioPortalId], references: [id])

    // Campos para Persona Jurídica
  tipoSociedad          String?  // SA, SRL, SAS, COOPERATIVA, ASOCIACION_CIVIL
  representanteNombre   String?
  representanteDni      String?

  // Campo para Persona Física
  bienesEmbargables     String?  // SI, NO, NO_CORRESPONDE

  @@index([usuarioPortalId])
  @@index([creadoPorId])
  @@index([numeroDocumento])
  @@index([email])
  @@index([abogadoId])
  @@map("cliente")
}

model Caso {
  id                String        @id @default(uuid())
  numero            String        @unique(map: "Caso_numero_key")
  titulo            String
  descripcion       String        @db.Text
  tipo              TipoCaso
  estado            String
  fechaUltimoCambioEstado DateTime      @default(now())
  porcentajeAvance  Int           @default(0)
  fechaInicio       DateTime
  abogadoId         String
  clienteId         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  isFavorite        Boolean       @default(false)
  priority          Priority      @default(NORMAL)
  fechaFin          DateTime?
  contraparteDni    String?
  contraparteNombre String?
  fuero             String?
  juzgado           String?
  montoDisputa      Decimal?      @db.Decimal(15, 2)
  ubicacionFisica   String?
  cerradoPorId      String?
  estaCerrado       Boolean       @default(false)
  estadoAntesCierre String?
  fechaCierre       DateTime?
  montoFinal        Decimal?      @db.Decimal(15, 2)
  motivoCierre      String?
  observacionCierre String?       @db.Text
  provincia    String?
  ciudad       String?

  bitacoras         Bitacora[]
  abogado           User          @relation("AbogadoCasos", fields: [abogadoId], references: [id])
  cliente           Cliente       @relation("ClienteCasos", fields: [clienteId], references: [id])
  pagos             Pago[]
  requirements      Requirement[]
  tareas            Tarea[]

  @@index([abogadoId], map: "Caso_abogadoId_fkey")
  @@index([clienteId], map: "Caso_clienteId_fkey")
  @@index([tipo])
  @@index([estado])
  @@index([contraparteDni])
  @@index([fechaUltimoCambioEstado]) 
  colaboradores  CasoColaborador[]
  @@map("caso")
}

model Requirement {
  id          String    @id @default(uuid())
  description String
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  casoId      String
  createdAt   DateTime  @default(now())
  caso        Caso      @relation(fields: [casoId], references: [id], onDelete: Cascade)

  @@index([casoId], map: "requirement_casoId_fkey")
  @@map("requirement")
}

model CasoColaborador {
  id            String   @id @default(cuid())
  casoId        String
  userId        String
  permiso       String   @default("LECTURA") // LECTURA o EDICION
  asignadoPorId String
  createdAt     DateTime @default(now())

  caso        Caso @relation(fields: [casoId], references: [id], onDelete: Cascade)
  usuario     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  asignadoPor User @relation("AsignadorColaboracion", fields: [asignadoPorId], references: [id])

  @@unique([casoId, userId])
  @@map("caso_colaborador")
}

model Tarea {
  id         String   @id @default(uuid())
  titulo     String
  prioridad  String   @default("Media")
  fatal      Boolean  @default(false)
  fecha      String?
  completada Boolean  @default(false)
  usuarioId  String
  casoId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  caso       Caso?    @relation(fields: [casoId], references: [id], onDelete: Cascade)
  usuario    User     @relation(fields: [usuarioId], references: [id])

  @@index([casoId], map: "tarea_casoId_fkey")
  @@index([usuarioId], map: "tarea_usuarioId_fkey")
  @@map("tarea")
}

model Bitacora {
  id             String   @id @default(uuid())
  texto          String   @db.Text
  tipo           String   @default("manual")
  usuarioId      String
  createdAt      DateTime @default(now())
  accion         String?
  casoId         String?
  detalle        String?  @db.Text
  estadoAnterior String?
  estadoNuevo    String?
  caso           Caso?    @relation(fields: [casoId], references: [id], onDelete: Cascade)
  usuario        User     @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([casoId])
  @@index([createdAt])
  @@index([accion])
  @@map("bitacora")
}

model Pago {
  id              String    @id @default(cuid())
  concepto        String
  descripcion     String?   @db.Text
  monto           Float
  estado          String    @default("pendiente")
  comprobanteUrl  String?   @db.Text
  comprobanteTipo String?
  montoPagado     Float?
  fechaPago       DateTime?
  validadoPor     String?
  fechaValidacion DateTime?
  notaValidacion  String?   @db.Text
  casoId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  caso            Caso      @relation(fields: [casoId], references: [id], onDelete: Cascade)
  validador       User?     @relation(fields: [validadoPor], references: [id])

  @@index([casoId])
  @@index([estado])
  @@index([validadoPor], map: "pago_validadoPor_fkey")
  @@map("pago")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "account_userId_fkey")
  @@map("account")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_userId_fkey")
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

enum Priority {
  HIGH
  NORMAL
  LOW
}

enum TipoPersona {
  FISICA
  JURIDICA
}

enum TipoDocumento {
  DNI
  CUIT
  CUIL
  PASAPORTE
  OTRO
}

enum CondicionIVA {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  EXENTO
  CONSUMIDOR_FINAL
  NO_CATEGORIZADO
}

enum TipoCaso {
  LABORAL
  CIVIL_COMERCIAL
  FAMILIA
  PENAL
  SUCESIONES
  CONTENCIOSO_ADMINISTRATIVO
  OTRO
}

enum UserRole {
  ADMIN
  ABOGADO
  ASISTENTE
  CLIENTE
}
