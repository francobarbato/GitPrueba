generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========== ENUMS ==========
enum Priority {
  HIGH
  NORMAL
  LOW
}

enum TipoPersona {
  FISICA
  JURIDICA
}

enum TipoDocumento {
  DNI
  CUIT
  CUIL
  PASAPORTE
  OTRO
}

enum CondicionIVA {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  EXENTO
  CONSUMIDOR_FINAL
  NO_CATEGORIZADO
}

enum TipoCaso {
  LABORAL
  CIVIL
  COMERCIAL
  FAMILIA
  PENAL
  SUCESIONES
  OTRO
}

enum UserRole {
  ADMIN       // Gestiona todo el sistema
  ABOGADO     // Gestiona casos y clientes
  ASISTENTE   // Apoya a abogados, acceso limitado
  CLIENTE     // Solo ve sus propios casos (futuro)
}

// ========== 1. MODELO USUARIO ==========
model User {
  id            String    @id @default(uuid())
  name          String?   
  email         String    @unique(map: "Usuario_email_key")
  emailVerified DateTime?
  image         String?
  password      String?
  
  nombre    String?
  apellido  String?
  rol       UserRole    @default(ABOGADO)
  isActive  Boolean  @default(true)

  creadoPor     String?    // ID del admin que lo creó
  debeResetearPassword Boolean @default(false)  // Para contraseñas temporales
  ultimoAcceso  DateTime?

  clienteVinculado  Cliente?  @relation("ClienteUsuarioPortal")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt




 // Relaciones del sistema
  clientes Cliente[] @relation("AbogadoClientes")
  casos    Caso[]    @relation("AbogadoCasos")
  pagosValidados Pago[]
  tareas    Tarea[]
  bitacoras Bitacora[]
  
  accounts Account[]
  sessions Session[]

  @@map("usuario")
}

// ========== 2. MODELO CLIENTE ==========
model Cliente {
  id                String         @id @default(uuid())
  
  // Datos de Identidad
  tipoPersona       TipoPersona    @default(FISICA)
  nombre            String
  apellido          String?        // Opcional si es Jurídica
  
  // Documentación ÚNICA (CRÍTICO)
  tipoDocumento     TipoDocumento  @default(DNI)
  numeroDocumento   String         @unique // ← EVITA DUPLICADOS
  
  // Contacto
  email             String?
  telefono          String?
  direccion         String?
  
  // Tributario (para facturación futura)
  condicionIva      CondicionIVA   @default(CONSUMIDOR_FINAL)
  
  // Metadata
  notasInternas     String?        @db.Text
  estado            String?        // Campo legacy (mantener por compatibilidad)
  activo            Boolean        @default(true) // Soft delete

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relaciones
  abogado           User           @relation("AbogadoClientes", fields: [abogadoId], references: [id])
  abogadoId         String
  casos             Caso[]         @relation("ClienteCasos")
  
  creadoPorId       String?

  usuarioPortalId   String?   @unique
  usuarioPortal     User?     @relation("ClienteUsuarioPortal", fields: [usuarioPortalId], references: [id])

  
  @@index([usuarioPortalId])
  @@index([creadoPorId])
  @@index([numeroDocumento])
  @@index([email])
  @@index([abogadoId])
  @@map("cliente")
}

// ========== 3. MODELO CASO ==========
model Caso {
  id                String    @id @default(uuid())
  numero            String    @unique(map: "Caso_numero_key")
  titulo            String
  descripcion       String    @db.Text
  
  // Clasificación (AHORA ES ENUM)
  tipo              TipoCaso
  estado            String    // Mantener String por flexibilidad procesal
  
  // Geolocalización Judicial
  juzgado           String?   // "Juzgado Nº 45 en lo Civil"
  fuero             String?   // "Capital Federal"
  
  // Conflicto de Interés 
  contraparteNombre String?
  contraparteDni    String?
  
  // Financiero 
  montoDisputa      Decimal?  @db.Decimal(15, 2)
  
  // Ubicación Física 
  ubicacionFisica   String?   // "Bibliorato A - Estante 2"
  
  // Control
  porcentajeAvance  Int       @default(0)
  priority          Priority  @default(NORMAL)
  isFavorite        Boolean   @default(false)
  
  // Fechas
  fechaInicio       DateTime
  fechaFin          DateTime? // Se llena automáticamente al cerrar

  estaCerrado       Boolean   @default(false)
  motivoCierre      String?   // FAVORABLE, DESFAVORABLE, ACUERDO, DESISTIMIENTO, ARCHIVO
  montoFinal        Decimal?  @db.Decimal(15, 2)
  fechaCierre       DateTime?
  observacionCierre String?   @db.Text
  cerradoPorId      String?
  estadoAntesCierre String?   // Para restaurar si se reabre
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relaciones adicionales
  pagos            Pago[]

  // Relaciones
  tareas            Tarea[]
  requirements      Requirement[] 
  bitacoras         Bitacora[]

  abogado           User      @relation("AbogadoCasos", fields: [abogadoId], references: [id])
  abogadoId         String

  cliente           Cliente   @relation("ClienteCasos", fields: [clienteId], references: [id])
  clienteId         String
  
  @@index([abogadoId], map: "Caso_abogadoId_fkey")
  @@index([clienteId], map: "Caso_clienteId_fkey")
  @@index([tipo])
  @@index([estado])
  @@index([contraparteDni]) // Para búsqueda de conflictos
  @@map("caso")
}

// ========== 4. CHECKLIST (Requisitos iniciales) ==========
model Requirement {
  id          String    @id @default(uuid()) 
  description String    
  dueDate     DateTime? 
  isCompleted Boolean   @default(false) 
  
  casoId      String    
  caso        Caso      @relation(fields: [casoId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  
  @@map("requirement")
}

// ========== 5. TAREAS (Agenda dentro del caso) ==========
model Tarea {
  id         String   @id @default(uuid())
  titulo     String
  prioridad  String   @default("Media")
  fatal      Boolean  @default(false)
  fecha      String?  // Fecha límite
  completada Boolean  @default(false)
  
  usuarioId  String
  usuario    User     @relation(fields: [usuarioId], references: [id])

  casoId     String?
  caso       Caso?    @relation(fields: [casoId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("tarea")
}

// ========== 6. BITÁCORA (Historial de movimientos) ==========
model Bitacora {
  id        String   @id @default(uuid())
  texto     String   @db.Text
  tipo      String   @default("manual") // 'manual', 'auto'
  accion    String?  // Ej: "Cambio de Estado"
  detalle   String?   @db.Text

  estadoAnterior String?  // Estado previo (para calcular tiempos)
  estadoNuevo    String?  // Estado nuevo
  
  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id])

  casoId    String?  
  caso      Caso?    @relation(fields: [casoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  
  @@index([usuarioId])
  @@index([casoId])
  @@index([createdAt])
  @@index([accion]) // Para filtrar por tipo de acción
  @@map("bitacora")
}

// Modelo para gestión de pagos y gastos del caso
model Pago {
  id               String   @id @default(cuid())
  concepto         String   // Honorarios, Sellados, Tasas, Gastos, etc.
  descripcion      String?  @db.Text
  monto            Float
  estado           String   @default("pendiente") // pendiente, pagado, validado
  
  // Comprobante subido por el cliente
  comprobanteUrl   String?  @db.Text
  comprobanteTipo  String?  // imagen, pdf
  montoPagado      Float?   // Monto que el cliente dice haber pagado
  fechaPago        DateTime?
  
  // Validación del abogado
  validadoPor      String?
  validador        User? @relation(fields: [validadoPor], references: [id])
  fechaValidacion  DateTime?
  notaValidacion   String?  @db.Text
  
  // Relación con caso
  casoId           String
  caso             Caso     @relation(fields: [casoId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([casoId])
  @@index([estado])

  @@map("pago")
}

// ========== AUTH.JS ==========
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}