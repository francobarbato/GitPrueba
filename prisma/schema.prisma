generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. MODELO USUARIO (Adaptado para Auth.js)
model User  {
  id            String       @id @default(uuid())
  name          String?   // Auth.js usa 'name' por defecto, mapeamos a 'nombre'/'apellido'
  email         String    @unique(map: "Usuario_email_key")
  emailVerified DateTime? // Requerido por Auth.js
  image         String?   // Requerido por Auth.js (foto de Google)
  password      String?   // Para credenciales (opcional si es solo Google)
  
  // Tus campos personalizados
  nombre        String?   // Opcional porque Google da 'name' completo
  apellido      String?   // Opcional porque Google da 'name' completo
  rol           String   @default("abogado") //mysql no soporta arrays postgr si...
  isActive      Boolean  @default(true)

  createdAt     DateTime  @default(now()) 
  updatedAt     DateTime  @updatedAt

  // Relaciones
  clientes Cliente[] @relation("AbogadoClientes")
  casos     Caso[] @relation("AbogadoCasos")

  // Relaciones de Auth.js
  accounts      Account[]
  sessions      Session[]

  @@map("usuario") // Mantiene tu nombre de tabla original
}

// 2. MODELO CLIENTE: Solo para datos de contacto
model Cliente {
  id                String       @id @default(uuid())
  nombre            String
  apellido          String
  email             String?  @unique
  numeroDocumento   String?  @unique
  tipoDocumento     String?
  direccion         String?
  telefono          String?
  estado            String? 

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relación con el abogado (usuario)
  abogado     User   @relation("AbogadoClientes", fields: [abogadoId], references: [id])
  abogadoId   String

  // Relación con casos del cliente
  casos       Caso[] @relation("ClienteCasos")

  
  

  @@map("cliente") // NUEVA TABLA EN MYSQL
}

// 3. MODELO CASO: Relaciones actualizadas
model Caso {
  id                String    @id @default(uuid())
  numero            String    @unique(map: "Caso_numero_key")
  titulo            String
  descripcion       String    @db.Text
  tipo              String
  estado            String
  porcentajeAvance  Int       @default(0)
  fechaInicio       DateTime
  fechaCierre       DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relación con el abogado
  abogado      User   @relation("AbogadoCasos", fields: [abogadoId], references: [id])
  abogadoId    String

  // Relación con el cliente
  cliente      Cliente @relation("ClienteCasos", fields: [clienteId], references: [id])
  clienteId    String
  
  @@index([abogadoId], map: "Caso_abogadoId_fkey")
  @@index([clienteId], map: "Caso_clienteId_fkey")
  @@map("caso")
}

// MODELOS DE AUTH.JS 
// ======================

model Account {
  id                 String @id @default(uuid()) //cambiar a uuid
  userId             String     // Cambiado a Int para coincidir con tu Usuario.id
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?


  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account") // Opcional: minúsculas para consistencia
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String      // Cambiado a Int
  expires      DateTime
  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}