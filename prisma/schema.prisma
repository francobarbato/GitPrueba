generator client {
  provider = "prisma-client-js"
}

// TODO: migrar a postrges y aprovechar mejor las relaciones
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique(map: "Usuario_email_key")
  nombre               String?
  apellido             String?
  password             String?
  rol                  UserRole   @default(ABOGADO)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  emailVerified        DateTime?
  image                String?
  name                 String?
  isActive             Boolean    @default(true)
  creadoPor            String?
  debeResetearPassword Boolean    @default(false)
  ultimoAcceso         DateTime?
  ultimoAccesoTareas   DateTime?
  ultimoAccesoComentarios DateTime?
  colaboracionesAsignadas CasoColaborador[] @relation("AsignadorColaboracion")


  accounts             Account[]
  bitacoras            Bitacora[]
  casos                Caso[]     @relation("AbogadoCasos")
  clientes             Cliente[]  @relation("AbogadoClientes")
  clienteVinculado     Cliente?   @relation("ClienteUsuarioPortal")
  pagosValidados       Pago[]
  sessions             Session[]

  passwordResetTokens     PasswordResetToken[]
  activationToken         AccountActivationToken?
  
  tareasCreadas      Tarea[] @relation("TareasCreadas")
  tareasAsignadas    Tarea[] @relation("TareasAsignadas")
  tareasSupervisadas Tarea[] @relation("TareasSupervisadas")
  documentos    Documento[]  @relation 

  colaboraciones CasoColaborador[]

    // Comentarios y lecturas
  comentariosEscritos ComentarioTarea[] @relation("ComentariosAutor")
  lecturasTarea      TareaLectura[]

  liquidacionesCreadas    Liquidacion[] @relation("LiquidacionesCreadas")
  liquidacionesEliminadas Liquidacion[] @relation("LiquidacionesEliminadas")

  @@map("usuario")
}

model Cliente {
  id              String        @id @default(uuid())
  nombre          String
  apellido        String?
  email           String?       @unique(map: "Cliente_email_key")
  numeroDocumento String        @unique
  tipoDocumento   TipoDocumento @default(DNI)
  direccion       String?
  telefono        String?       @unique(map: "Cliente_telefono_key")
  estado          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  abogadoId       String
  activo          Boolean       @default(true)
  condicionIva    CondicionIVA  @default(CONSUMIDOR_FINAL)
  notasInternas   String?       @db.Text
  tipoPersona     TipoPersona   @default(FISICA)
  creadoPorId     String?
  ultimoAccesoPortal  DateTime?

  
  usuarioPortalId String?       @unique
  casos           Caso[]        @relation("ClienteCasos")
  abogado         User          @relation("AbogadoClientes", fields: [abogadoId], references: [id])
  usuarioPortal   User?         @relation("ClienteUsuarioPortal", fields: [usuarioPortalId], references: [id])
  tareas          Tarea[]

    // Campos para Persona Jurídica
  tipoSociedad          String?  // SA, SRL, SAS, COOPERATIVA, ASOCIACION_CIVIL
  representanteNombre   String?
  representanteDni      String?

  // Campo para Persona Física
  bienesEmbargables     String?  // SI, NO, NO_CORRESPONDE

  @@index([usuarioPortalId])
  @@index([creadoPorId])
  @@index([numeroDocumento])
  @@index([email])
  @@index([abogadoId])
  @@map("cliente")
}

model Caso {
  id                String        @id @default(uuid())
  numero            String        @unique(map: "Caso_numero_key")
  titulo            String
  descripcion       String        @db.Text
  tipo              TipoCaso
  estado            String
  fechaUltimoCambioEstado DateTime      @default(now())
  porcentajeAvance  Int           @default(0)
  fechaInicio       DateTime
  abogadoId         String
  clienteId         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  isFavorite        Boolean       @default(false)
  priority          Priority      @default(NORMAL)
  fechaFin          DateTime?
  contraparteDni    String?
  contraparteNombre String?
  fuero             String?
  juzgado           String?
  montoDisputa      Decimal?      @db.Decimal(15, 2)
  ubicacionFisica   String?
  cerradoPorId      String?
  estaCerrado       Boolean       @default(false)
  estadoAntesCierre String?
  fechaCierre       DateTime?
  montoFinal        Decimal?      @db.Decimal(15, 2)
  motivoCierre      String?
  observacionCierre String?       @db.Text
  provincia    String?
  ciudad       String?
  esTraspasado    Boolean   @default(false)
  fechaTraspaso   DateTime?
  estudioDestino  String?           
  motivoTraspaso  String?  @db.Text

    // ── Buffer de "recibido por reasignación" ──────────────────────────
  recibidoEnReasignacion  Boolean   @default(false)
  fechaReasignacion       DateTime?

  bitacoras         Bitacora[]
  abogado           User          @relation("AbogadoCasos", fields: [abogadoId], references: [id])
  cliente           Cliente       @relation("ClienteCasos", fields: [clienteId], references: [id])
  pagos             Pago[]
  requirements      Requirement[]
  tareas            Tarea[]
  documentos        Documento[] 
  contraparte       Contraparte?
  carpetas          Carpeta[]
  liquidaciones     Liquidacion[]

  @@index([abogadoId], map: "Caso_abogadoId_fkey")
  @@index([clienteId], map: "Caso_clienteId_fkey")
  @@index([tipo])
  @@index([estado])
  @@index([contraparteDni])
  @@index([fechaUltimoCambioEstado]) 
  colaboradores  CasoColaborador[]
  @@map("caso")
}

model Requirement {
  id          String    @id @default(uuid())
  description String
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  casoId      String
  createdAt   DateTime  @default(now())
  caso        Caso      @relation(fields: [casoId], references: [id], onDelete: Cascade)

  @@index([casoId], map: "requirement_casoId_fkey")
  @@map("requirement")
}

model CasoColaborador {
  id            String   @id @default(cuid())
  casoId        String
  userId        String
  permiso       String   @default("LECTURA") // LECTURA o EDICION
  asignadoPorId String
  createdAt     DateTime @default(now())

  caso        Caso @relation(fields: [casoId], references: [id], onDelete: Cascade)
  usuario     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  asignadoPor User @relation("AsignadorColaboracion", fields: [asignadoPorId], references: [id])

  @@unique([casoId, userId])
  @@map("caso_colaborador")
}

model Contraparte {
  id          String      @id @default(uuid())
  casoId      String      @unique
  caso        Caso        @relation(fields: [casoId], references: [id], onDelete: Cascade)

  tipoPersona TipoPersona @default(FISICA)
  nombre      String
  apellido    String?
  documento   String?
  rol         String?
  domicilio   String?
  localidad   String?
  provincia   String?
  notas       String?     @db.Text

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("contraparte")
}

model Liquidacion {
  id          String          @id @default(cuid())
  tipo        TipoLiquidacion
  montoTotal  Decimal         @db.Decimal(15, 2)
  detalle     Json            // snapshot completo: parámetros + desglose
  descripcion String?

  casoId      String?
  caso        Caso?           @relation(fields: [casoId], references: [id], onDelete: SetNull)

  creadoPorId String
  creadoPor   User            @relation("LiquidacionesCreadas", fields: [creadoPorId], references: [id])

  // Soft delete: nunca se borra físicamente
  eliminadoEn      DateTime?
  eliminadoPorId   String?
  eliminadoPor     User?      @relation("LiquidacionesEliminadas", fields: [eliminadoPorId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([casoId])
  @@index([tipo])
  @@index([creadoPorId])
  @@index([eliminadoEn])
  @@map("liquidacion")
}

enum TipoLiquidacion {
  DESPIDO
  LRT
  CAPITALIZACION
}

model Tarea {
  id               String         @id @default(uuid())
  titulo           String
  descripcion      String?        @db.Text
  tipo             TipoTarea      @default(INTERNA)
  categoria        CategoriaTarea @default(REUNION_CLIENTE)
  ambito           AmbitoTarea    @default(INTERNO)
  prioridad        PrioridadTarea @default(MEDIA)
  estado           EstadoTarea    @default(PENDIENTE)
  motivoBloqueo    String?        @db.Text
  motivoDesbloqueo String?        @db.Text
  fechaVencimiento DateTime?
  fechaInicio      DateTime?
  fechaCompletada  DateTime?
  lugarFisico      String?
  visibleCliente   Boolean        @default(false)
  clienteId        String?

  motivoCierreVencida String?   @db.Text
  vencidaCerradaEn    DateTime?
  vencidaCerradaPorId String? 

  // Relaciones de actores
  casoId           String?
  cliente          Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  creadorId        String
  responsableId    String
  supervisorId     String?

  caso             Caso?          @relation(fields: [casoId], references: [id], onDelete: SetNull)
  creador          User           @relation("TareasCreadas", fields: [creadorId], references: [id])
  responsable      User           @relation("TareasAsignadas", fields: [responsableId], references: [id])
  supervisor       User?          @relation("TareasSupervisadas", fields: [supervisorId], references: [id])
  
  bitacoras        Bitacora[]

  // Comentarios e historial de lectura
  comentarios      ComentarioTarea[]
  lecturas         TareaLectura[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([casoId])
  @@index([clienteId])
  @@index([creadorId])
  @@index([responsableId])
  @@index([supervisorId])
  @@index([estado])
  @@index([fechaVencimiento])
  @@map("tarea")
}

// ============================================================================
// MODELO DE COMENTARIOS DE TAREA
// Permite conversación contextual entre responsable y supervisor.
// Soporta cita opcional (responder a otro comentario) sin hilos anidados.
// ============================================================================
model ComentarioTarea {
  id           String   @id @default(uuid())
  texto        String   @db.Text
  tareaId      String
  autorId      String

  // Cita opcional a otro comentario de la misma tarea
  citaComentarioId    String?
  citaComentario      ComentarioTarea?  @relation("CitaRelation", fields: [citaComentarioId], references: [id], onDelete: SetNull)
  citadoEnComentarios ComentarioTarea[] @relation("CitaRelation")

  createdAt    DateTime @default(now())

  tarea        Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  autor        User     @relation("ComentariosAutor", fields: [autorId], references: [id])

  @@index([tareaId])
  @@index([autorId])
  @@index([createdAt])
  @@map("comentario_tarea")
}

// ============================================================================
// LECTURA DE TAREAS — granularidad usuario/tarea
// Permite saber si un usuario tiene comentarios sin leer en una tarea.
// Al abrir el Drawer de una tarea, se upsertea el registro con now().
// ============================================================================
model TareaLectura {
  userId        String
  tareaId       String
  ultimaLectura DateTime @default(now())
  ultimoUmbralVencimientoVisto Int?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tarea Tarea @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@id([userId, tareaId])
  @@index([tareaId])
  @@map("tarea_lectura")
}

model Bitacora {
  id             String   @id @default(uuid())
  texto          String   @db.Text
  tipo           String   @default("manual")
  usuarioId      String
  createdAt      DateTime @default(now())
  accion         String?
  casoId         String?
  detalle        String?  @db.Text
   tareaId        String? 
  estadoAnterior String?
  estadoNuevo    String?
  caso           Caso?    @relation(fields: [casoId], references: [id], onDelete: Cascade)
  usuario        User     @relation(fields: [usuarioId], references: [id])
  tarea          Tarea?   @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([tareaId]) 
  @@index([casoId])
  @@index([createdAt])
  @@index([accion])
  @@map("bitacora")
}

model Documento {
  id            String    @id @default(uuid())
  nombre        String                          // "Demanda_inicial.pdf"
  nombreOriginal String                         // nombre tal como lo subió el usuario
  storageKey    String                          // clave en el storage (path relativo o key S3)
  url           String?                         // URL pública o firmada (opcional)
  tipo          String                          // "application/pdf", "image/png", etc.
  extension     String                          // "pdf", "docx", "jpg"
  tamanio       Int                             // bytes
  descripcion   String?   @db.Text
  esInterno     Boolean   @default(false)       // true = no visible para cliente
  
  // Relaciones
  casoId        String
  caso          Caso      @relation(fields: [casoId], references: [id], onDelete: Cascade)

  carpetaId     String?
  carpetaRef    Carpeta?  @relation(fields: [carpetaId], references: [id], onDelete: Cascade)
  
  subidoPorId   String
  subidoPor     User      @relation(fields: [subidoPorId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([casoId])
  @@index([subidoPorId])
  @@index([carpetaId])
  @@map("documento")
}

model Carpeta {
  id              String      @id @default(uuid())
  nombre          String
  casoId          String
  carpetaPadreId  String?     // null = raíz del expediente; con valor = anidada

  caso            Caso        @relation(fields: [casoId], references: [id], onDelete: Cascade)
  carpetaPadre    Carpeta?    @relation("CarpetasAnidadas", fields: [carpetaPadreId], references: [id], onDelete: Cascade)
  subcarpetas     Carpeta[]   @relation("CarpetasAnidadas")
  documentos      Documento[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([casoId])
  @@index([carpetaPadreId])
  @@map("carpeta")
}


model Pago {
  id              String    @id @default(cuid())
  concepto        String
  descripcion     String?   @db.Text
  monto           Float
  estado          String    @default("pendiente")
  comprobanteUrl  String?   @db.Text
  comprobanteTipo String?
  montoPagado     Float?
  fechaPago       DateTime?
  validadoPor     String?
  fechaValidacion DateTime?
  notaValidacion  String?   @db.Text
  casoId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  caso            Caso      @relation(fields: [casoId], references: [id], onDelete: Cascade)
  validador       User?     @relation(fields: [validadoPor], references: [id])

  @@index([casoId])
  @@index([estado])
  @@index([validadoPor], map: "pago_validadoPor_fkey")
  @@map("pago")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "account_userId_fkey")
  @@map("account")
}

// ============================================================================
// TOKENS DE AUTH (independientes del VerificationToken de NextAuth)
// ============================================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique          // valor opaco que viaja en la URL
  userId    String
  expiresAt DateTime                  // 1 hora desde la creación
  usedAt    DateTime?                 // null hasta que se consume; al consumirse, queda fijado
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_token")
}

model AccountActivationToken {
  id        String   @id @default(cuid())
  token     String   @unique          // valor opaco que viaja en la URL
  userId    String   @unique          // un usuario tiene UN solo token de activación activo
  expiresAt DateTime                  // 48 horas desde la creación
  usedAt    DateTime?                 // se setea cuando el usuario completa la activación
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("account_activation_token")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_userId_fkey")
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

enum Priority {
  HIGH
  NORMAL
  LOW
}

enum TipoPersona {
  FISICA
  JURIDICA
}

enum TipoDocumento {
  DNI
  CUIT
  CUIL
  PASAPORTE
  OTRO
}

enum CondicionIVA {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  EXENTO
  CONSUMIDOR_FINAL
  NO_CATEGORIZADO
}

enum TipoCaso {
  LABORAL
  CIVIL_COMERCIAL
  FAMILIA
  PENAL
  SUCESIONES
  CONTENCIOSO_ADMINISTRATIVO
  OTRO
}

enum UserRole {
  ADMIN
  ABOGADO
  ASISTENTE
  CLIENTE
}

enum TipoTarea {
  PROCESAL
  INTERNA
}

enum CategoriaTarea {
  PRESENTACION_ESCRITO
  AUDIENCIA
  NOTIFICACION_CEDULA
  CONTROL_EXPEDIENTE
  APELACION_RECURSO
  PERICIA_PRUEBA
  REUNION_CLIENTE
  REDACCION_DOCUMENTACION
  TRAMITE_ADMINISTRATIVO
  REQUERIMIENTO_CLIENTE
  GESTION_FINANCIERA
  REUNION_EQUIPO
  VENCIMIENTO_PLAZO
}

enum AmbitoTarea {
  INTERNO
  EXTERNO
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
  FATAL
}

enum EstadoTarea {
  PENDIENTE
  EN_PROCESO
  BLOQUEADA
  COMPLETADA
  VENCIDA
}
